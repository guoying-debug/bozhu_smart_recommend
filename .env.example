# 智谱 API Key（默认用于 LLM 功能）
ZHIPU_API_KEY=your-zhipu-api-key-here
# 兼容旧变量名（二选一即可）
# ZHIPUAI_API_KEY=your-zhipu-api-key-here

# 可选：统一覆盖 LLM 配置
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=glm-4-flash-250414

# Hugging Face / Transformers 配置
HF_ENDPOINT=https://hf-mirror.com
HUGGINGFACE_HUB_ENDPOINT=https://hf-mirror.com
BERT_MODEL_ID=bert-base-chinese
# LOCAL_BERT_MODEL_DIR=/app/models/hf/bert-base-chinese

# MySQL 数据库配置
# Docker Compose 场景下推荐使用 DB_HOST=db
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root_password
DB_NAME=bilibili_data

# Docker 初始化行为
AUTO_LOAD_DATA=true
AUTO_TRAIN_MODEL=true
AUTO_BUILD_CHROMA=true
DB_WAIT_TIMEOUT=180

# Flask / 调度配置
ENABLE_SCHEDULER=true
